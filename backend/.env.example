# ===========================================================================
#  ResQ Backend — Environment Variables
#  Copy to `.env` for local dev. On Render, set these in the dashboard
#  (Environment tab) — do NOT commit real secrets.
# ===========================================================================

# ── Server ──────────────────────────────────────────────────────────────────
# Render injects PORT automatically; locally defaults to 5000.
PORT=5000
NODE_ENV=development

# Supabase pooler uses a self-signed cert. Keep "0" so the pg/Supabase clients
# don't reject the connection. (The app also sets this in code as a safeguard.)
NODE_TLS_REJECT_UNAUTHORIZED=0

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Use the Supabase "Connection pooling" (pgBouncer) string, port 5432/6543.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres

# ── Better Auth ─────────────────────────────────────────────────────────────
# Generate a strong 32+ char secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=your_better_auth_secret_min_32_chars
# Local: http://localhost:5000 — Production: your Render backend URL
BETTER_AUTH_URL=http://localhost:5000

# ── AI-ML Service (Python / FastAPI on Render) ──────────────────────────────
# Local: http://localhost:8000 — Production: your Render AI-ML service URL
AI_ML_SERVICE_URL=http://localhost:8000

# ── Frontend URL (CORS + Better Auth trusted origins) ───────────────────────
# Single origin OR comma-separated list (prod + custom domains).
# Any *.vercel.app preview deployment is auto-allowed by the server.
# Local: http://localhost:3000 — Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
