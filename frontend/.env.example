# ===========================================================================
#  ResQ Frontend (Next.js) — Environment Variables
#  Set these in Vercel: Project → Settings → Environment Variables.
#  Only NEXT_PUBLIC_* vars are exposed to the browser (required here).
# ===========================================================================

# Base URL of the Express backend on Render (no trailing slash).
# Used for REST (axios) and Better Auth.
# Local: http://localhost:5000 — Production: https://resq-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Socket.IO server URL — almost always the SAME as the backend URL.
# Local: http://localhost:5000 — Production: https://resq-backend.onrender.com
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
